{
  "name": "transport-clock-gpt",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --dotenv .env.local",
    "tsc": "nuxt typecheck",
    "build": "nuxt build",
    "build:capacitor": "nuxt generate --dotenv .env.capacitor",
    "dev:capacitor": "nuxt dev --dotenv .env.capacitor --host 0.0.0.0 --port 5173",
    "capacitor:sync": "npx cap sync",
    "capacitor:sync:android:live": "set \"CAPACITOR_LIVE_RELOAD=true\" && npx cap sync android",
    "capacitor:android": "npx cap open android",
    "capacitor:ios": "npx cap open ios",
    "preview": "nuxt preview --host 127.0.0.1",
    "test": "vitest run"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.1",
    "@dagrejs/dagre": "^3.0.0",
    "@tsparticles/slim": "^4.0.5",
    "@tsparticles/vue3": "^4.0.5",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "fflate": "^0.8.3",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "3.20.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@nuxt/test-utils": "3.20.1",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  },
  "packageManager": "yarn@1.22.19+sha1.4ba7fc5c6e704fce2066ecbfb0b0d8976fe62447"
}
