IDFM_API_KEY=replace-with-your-idfm-prim-token
# Required only for `npm run build:capacitor`. This is the public URL of the
# deployed Nuxt backend that serves the /api routes (without a trailing slash).
# NUXT_PUBLIC_API_BASE_URL=https://transport-clock.example.com
# IDFM_NETEX_CACHE_LOCAL=../idfm-node-backend/public/data/netex
IDFM_NETEX_CACHE_REMOTE=r2://idfm-backend-netex-cache/netex/current
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
# Optional Home Assistant API protection and stable deployment identity.
# TRANSPORT_CLOCK_HA_TOKEN=replace-with-a-long-random-token
# TRANSPORT_CLOCK_INSTANCE_ID=transport-clock-production
