# Used by `npm run apk:build` and `npm run apk:publish`.
# Copy this file to .env.mobile-release, load it in your shell, then keep it private.
NUXT_PUBLIC_API_BASE_URL=https://your-pages-project.pages.dev
MOBILE_RELEASE_VERSION_CODE=1001
# Optional. Defaults to the package version plus the version code.
MOBILE_RELEASE_VERSION_NAME=0.1.0+1001

# Local path to the stable release keystore. Never commit this file or the keystore.
MOBILE_RELEASE_KEYSTORE_PATH=C:/path/to/transport-clock-release.jks
MOBILE_RELEASE_KEYSTORE_PASSWORD=
MOBILE_RELEASE_KEY_ALIAS=
MOBILE_RELEASE_KEY_PASSWORD=
# The signing certificate SHA-256 is extracted automatically from the APK.

# R2 S3 API credentials with write access only to the release bucket.
MOBILE_RELEASE_R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
MOBILE_RELEASE_R2_BUCKET=transport-clock-mobile-releases
MOBILE_RELEASE_R2_ACCESS_KEY_ID=
MOBILE_RELEASE_R2_SECRET_ACCESS_KEY=
